PORT=5000
NODE_ENV=production
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/medibridge?retryWrites=true&w=majority
JWT_SECRET=your_production_jwt_secure_secret_key
JWT_EXPIRES_IN=7d
CORS_ORIGIN=https://your-medibridge-frontend.vercel.app
GEMINI_API_KEY=your_gemini_api_key_here
