# ─── Application Mode ─────────────────────────────────────────────────────────
# Set to 'true' to run in Demo Mode (no backend required, uses local mock data).
# Set to 'false' (or omit) to run in Production Mode (Railway backend + MongoDB).
VITE_DEMO_MODE=true

# ─── Backend API ──────────────────────────────────────────────────────────────
# Only used in Production Mode (VITE_DEMO_MODE=false).
# Demo Mode never reads this variable.
VITE_API_URL=https://medibridge-production-162c.up.railway.app/api
